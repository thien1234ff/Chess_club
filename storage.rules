rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() { 
      return request.auth != null; 
    }
    
    match /avatars/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if signedIn() && request.auth.uid == userId;
    }
    
    match /covers/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if signedIn() && request.auth.uid == userId;
    }
    
    match /posts/{postId}/{allPaths=**} {
      allow read: if true;
      allow write: if signedIn();
    }
    
    match /clubs/{clubId}/{allPaths=**} {
      allow read: if true;
      allow write: if signedIn();
    }
    
    match /tournaments/{tournamentId}/{allPaths=**} {
      allow read: if true;
      allow write: if signedIn();
    }
  }
}
